<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,sans-serif;font-size:16px;color:#c9d1d9;background:#0d1117;max-width:800px;margin:40px auto;padding:0 20px;line-height:1.8}
h1{color:#58a6ff;margin-bottom:24px}
h2{color:#f0f6fc;margin-top:32px;margin-bottom:12px;font-size:20px}
